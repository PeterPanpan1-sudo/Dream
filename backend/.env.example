# Server Configuration
PORT=8000
NODE_ENV=production

# Security
JWT_SECRET=change_this_to_a_random_secret_key_in_production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database
DATABASE_PATH=./data/daydream.db

# File Storage
UPLOAD_DIR=./data/uploads

# Cloudflare temporary domain mail registrar
# Worker URL 示例：https://your-temp-mail-worker.your-subdomain.workers.dev
TEMP_MAIL_WORKER_URL=
TEMP_MAIL_ADMIN_AUTH=
TEMP_MAIL_DOMAIN=edu.peterlinux.com
TEMP_MAIL_ENABLE_PREFIX=true
